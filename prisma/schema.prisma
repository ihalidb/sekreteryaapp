 // This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Mahalle {
  id              Int            @id @default(autoincrement())
  ad              String
  aciklama        String?
  lokalYeri       String?
  mahalleBaskanId Int?           @unique
  mahalleBaskan   Uye?           @relation("MahalleBaskan", fields: [mahalleBaskanId], references: [id], onDelete: SetNull)
  mahalleBaskanDetay MahalleBaskan? @relation("MahalleBaskanDetay")
  sorumluUyeler   UyeMahalle[]
  sorumluYonetimKurulu YonetimKuruluMahalle[] @relation("YonetimKuruluSorumlu")
  talepler        Talep[]        @relation("TalepMahalle")
  createdBy       Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("mahalleler")
}

model IlceGorev {
  id                    Int                    @id @default(autoincrement())
  ad                    String                 @unique
  aciklama              String?
  sira                  Int                    @default(0)
  uyeler                Uye[]
  yonetimKuruluUyeleri  YonetimKuruluUyesi[]   @relation("YonetimKuruluIlceGorev")
  createdBy             Int?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@map("ilce_gorevler")
}

model Uye {
  id               Int               @id @default(autoincrement())
  ad               String
  soyad            String
  telefon          String?
  email            String?
  adres            String?
  ilceGorevId      Int?
  ilceGorev        IlceGorev?        @relation(fields: [ilceGorevId], references: [id], onDelete: SetNull)
  komisyonlar      UyeKomisyon[]
  sorumluMahalleler UyeMahalle[]
  yoklamalar       EtkinlikYoklama[]
  mahalleBaskanlik Mahalle?          @relation("MahalleBaskan")
  createdBy        Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([ilceGorevId])
  @@index([ad, soyad])
  @@map("uyeler")
}

model UyeKomisyon {
  id          Int       @id @default(autoincrement())
  uyeId       Int
  komisyonId  Int
  gorev       String?
  uye         Uye       @relation(fields: [uyeId], references: [id], onDelete: Cascade)
  komisyon    Komisyon  @relation(fields: [komisyonId], references: [id], onDelete: Cascade)
  createdBy   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([uyeId, komisyonId])
  @@map("uye_komisyon")
}

model UyeMahalle {
  id         Int      @id @default(autoincrement())
  uyeId      Int
  mahalleId  Int
  uye        Uye      @relation(fields: [uyeId], references: [id], onDelete: Cascade)
  mahalle    Mahalle  @relation(fields: [mahalleId], references: [id], onDelete: Cascade)
  createdBy  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([uyeId, mahalleId])
  @@map("uye_mahalle")
}

model Etkinlik {
  id                    Int               @id @default(autoincrement())
  ad                    String
  aciklama              String?
  tarih                 DateTime
  konum                 String?
  zorunlu               Boolean           @default(true)
  yoklamalar            EtkinlikYoklama[]
  komisyonlar           EtkinlikKomisyon[]
  ilceYonetimKuruluEkle Boolean           @default(false)
  createdBy             Int?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([tarih])
  @@map("etkinlikler")
}

model EtkinlikKomisyon {
  id          Int       @id @default(autoincrement())
  etkinlikId  Int
  komisyonId  Int
  etkinlik    Etkinlik  @relation(fields: [etkinlikId], references: [id], onDelete: Cascade)
  komisyon    Komisyon  @relation(fields: [komisyonId], references: [id], onDelete: Cascade)
  createdBy   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([etkinlikId, komisyonId])
  @@map("etkinlik_komisyon")
}

model Komisyon {
  id         Int              @id @default(autoincrement())
  ad         String
  aciklama   String?
  baskanId   Int?
  baskan     YonetimKuruluUyesi? @relation("KomisyonBaskan", fields: [baskanId], references: [id], onDelete: SetNull)
  uyeler     UyeKomisyon[]
  etkinlikler EtkinlikKomisyon[]
  createdBy  Int?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([baskanId])
  @@map("komisyonlar")
}

model EtkinlikYoklama {
  id          Int       @id @default(autoincrement())
  etkinlikId  Int
  uyeId       Int
  katildi     Boolean   @default(false)
  notlar      String?
  etkinlik    Etkinlik  @relation(fields: [etkinlikId], references: [id], onDelete: Cascade)
  uye         Uye       @relation(fields: [uyeId], references: [id], onDelete: Cascade)
  createdBy   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([etkinlikId, uyeId])
  @@map("etkinlik_yoklama")
}

model YonetimKuruluUyesi {
  id               Int                    @id @default(autoincrement())
  ad               String
  soyad            String
  ilceGorevId      Int?
  ilceGorev        IlceGorev?             @relation("YonetimKuruluIlceGorev", fields: [ilceGorevId], references: [id], onDelete: SetNull)
  telefon          String?
  email            String?
  adres            String?
  sira             Int                    @default(0)
  adminId          Int?                   @unique
  admin            Admin?                 @relation("YKAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  sorumluMahalleler YonetimKuruluMahalle[]
  komisyonlar      Komisyon[]             @relation("KomisyonBaskan")
  atananTalepler   Talep[]                @relation("TalepAtanan")
  createdBy        Int?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([sira])
  @@index([ilceGorevId])
  @@index([adminId])
  @@map("yonetim_kurulu_uyeleri")
}

model YonetimKuruluMahalle {
  id                    Int                @id @default(autoincrement())
  yonetimKuruluUyesiId  Int
  yonetimKuruluUyesi    YonetimKuruluUyesi @relation(fields: [yonetimKuruluUyesiId], references: [id], onDelete: Cascade)
  mahalleId             Int
  mahalle               Mahalle            @relation("YonetimKuruluSorumlu", fields: [mahalleId], references: [id], onDelete: Cascade)
  createdAt             DateTime           @default(now())

  @@unique([yonetimKuruluUyesiId, mahalleId])
  @@index([yonetimKuruluUyesiId])
  @@index([mahalleId])
  @@map("yonetim_kurulu_mahalle")
}

model MahalleBaskan {
  id         Int      @id @default(autoincrement())
  ad         String
  soyad      String
  mahalleId  Int?     @unique
  mahalle    Mahalle? @relation("MahalleBaskanDetay", fields: [mahalleId], references: [id], onDelete: SetNull)
  telefon    String?
  email      String?
  adres      String?
  adminId    Int?     @unique
  admin      Admin?   @relation("MBAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  createdBy  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([mahalleId])
  @@index([adminId])
  @@map("mahalle_baskanlari")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

enum TalepDurum {
  YENI
  ATANDI
  ISLEMDE
  COZULDU
  KAPALI
  REDDEDILDI
}

enum TalepOncelik {
  DUSUK
  NORMAL
  YUKSEK
  ACIL
}

model AdminIzin {
  id              Int       @id @default(autoincrement())
  adminId         Int       @unique
  admin           Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  mahalleler      String    @default("none")
  uyeler          String    @default("none")
  etkinlikler     String    @default("none")
  komisyonlar     String    @default("none")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("admin_izinler")
}

model TalepKategori {
  id        Int      @id @default(autoincrement())
  ad        String
  aciklama  String?
  renk      String   @default("#6366f1")
  sira      Int      @default(0)
  active    Boolean  @default(true)
  talepler  Talep[]
  createdBy Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sira])
  @@map("talep_kategoriler")
}

model Talep {
  id          Int                  @id @default(autoincrement())
  baslik      String
  aciklama    String?
  kategoriId  Int?
  kategori    TalepKategori?       @relation(fields: [kategoriId], references: [id], onDelete: SetNull)
  mahalleId   Int?
  mahalle     Mahalle?             @relation("TalepMahalle", fields: [mahalleId], references: [id], onDelete: SetNull)
  olusturanId Int
  olusturan   Admin                @relation("TalepOlusturan", fields: [olusturanId], references: [id])
  atananYKId  Int?
  atananYK    YonetimKuruluUyesi?  @relation("TalepAtanan", fields: [atananYKId], references: [id], onDelete: SetNull)
  durum       TalepDurum           @default(YENI)
  oncelik     TalepOncelik         @default(NORMAL)
  notlar      Json                 @default("[]")
  createdBy   Int?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([olusturanId])
  @@index([atananYKId])
  @@index([mahalleId])
  @@index([durum])
  @@map("talepler")
}

model Admin {
  id             Int                  @id @default(autoincrement())
  username       String               @unique
  password       String
  name           String?
  email          String?
  active         Boolean              @default(true)
  role           AdminRole            @default(ADMIN)
  izinler        AdminIzin?
  mahalleBaskan  MahalleBaskan?       @relation("MBAdmin")
  ykUyesi        YonetimKuruluUyesi?  @relation("YKAdmin")
  talepler       Talep[]              @relation("TalepOlusturan")
  sessionToken   String?              @unique
  sessionExpiry  DateTime?
  lastLogin      DateTime?
  createdBy      Int?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([username])
  @@index([sessionToken])
  @@map("admins")
}
